select(c(contrast, .value, .lower, .upper))
pairwise_reduced
tableApp1 = print(xtable(pairwise_reduced),
#only.contents = T,
include.rownames=FALSE,
include.colnames=TRUE,
tabular.environment="longtable",
floating=FALSE,
