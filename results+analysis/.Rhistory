# extract demographic data
dg <- data_full %>%
select(
participant,
starts_with("A20")
) %>%
slice(-1) %>%
mutate(participant = as.factor(participant),
standardAmE = case_when(A201_01 == "Checked" ~ TRUE,
A201_01 == "Not checked" ~ FALSE,
A201_01 == NA ~ NA),
standardBrE = case_when(A201_02 == "Checked" ~ TRUE,
A201_02 == "Not checked" ~ FALSE,
A201_02 == NA ~ NA),
standardOther = case_when(A201_03 == "Checked" ~ TRUE,
A201_03 == "Not checked" ~ FALSE,
A201_03 == NA ~ NA),
standardOtherWhich = as.factor(A201_03a),
likes = as.factor(as.character(A202)),
lived_in = as.factor(case_when(A203 == "I have not" ~ NA,
TRUE ~ as.character(A203))),
years_taught = as.numeric(str_extract(A204_01, "\\d+")),
native_lang = as.factor(case_when(A205 == "Other (please specify)" ~ as.character(A205_03),
TRUE ~ as.character(A205))),
age = as.numeric(str_extract(A206_01, "\\d+")),
.keep = "none")
# remove data from participants that did not complete the surevy
incomplete_ids <- d %>% group_by(participant) %>%
summarize(incomplete = any(is.na(rating)), .groups = "drop") %>%
filter(incomplete) %>% pull(participant)
length(incomplete_ids)
d_clean <- d %>% filter(!participant %in% incomplete_ids)  %>% mutate(participant = fct_drop(participant)) %>% arrange(participant)
dg_clean <- dg %>% filter(!participant %in% incomplete_ids )%>% mutate(participant = fct_drop(participant)) %>% arrange(participant)
# replace participant by running number
length(unique(d_clean$participant)) # 41 filled out the entire survey
levels(d_clean$participant) <- 1:length(unique(d_clean$participant))
levels(dg_clean$participant) <- 1:length(unique(d_clean$participant))
summary(dg)
summary(dg_clean)
View(dg_clean)
write_csv(d_clean, file="data_table.csv")
write_csv(dg_clean, file="demographic.csv")
d_clean %>% ggplot(aes(x = factor(rating))) +
geom_bar(fill = "lightblue") +
labs(x = "Rating", y = "Count") +
theme_minimal()
d_clean %>% ggplot(aes(x = factor(rating))) +
geom_bar(fill = "lightblue") +
facet_wrap(~ characteristic) +
labs(x = "Rating", y = "Count") +
theme_minimal()
d_clean %>% ggplot(aes(x = factor(rating))) +
geom_bar(fill = "lightblue") +
facet_wrap(~ recording) +
labs(x = "Rating", y = "Count") +
theme_minimal()
d_clean %>% ggplot(aes(x = factor(rating))) +
geom_bar(fill = "lightblue") +
facet_wrap(~ variety) +
labs(x = "Rating", y = "Count") +
theme_minimal()
d_clean %>% ggplot(aes(x = factor(rating))) +
geom_bar(fill = "lightblue") +
facet_wrap(~ sp_gender) +
labs(x = "Rating", y = "Count") +
theme_minimal()
