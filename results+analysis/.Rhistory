library(tidyverse)
data_full = read_csv2("data-1.csv")
View(data_full)
# replace participant by running number
length(unique(data_full$CASE)) # 44
data_full$participant <- as.factor(as.character(data_full$CASE))
levels(data_full$participant) <- 1:length(unique(data_full$participant))
data_full %>%
select(
participant,
starts_with("A20")
)
data_full %>%
select(
participant,
starts_with("A20")
) %>%
slice(-1) %>%
data_full %>%
select(
participant,
starts_with("A20")
) %>%
slice(-1)
dg <- data_full %>%
select(
participant,
starts_with("A20")
) %>%
slice(-1) %>%
mutate(participant = as.factor(participant),
standardAmE = case_when(A201_01 == "Checked" ~ TRUE,
A201_01 == "Not checked" ~ FALSE,
A201_01 == NA ~ NA),
standardBrE = case_when(A201_02 == "Checked" ~ TRUE,
A201_02 == "Not checked" ~ FALSE,
A201_02 == NA ~ NA),
standardOther = case_when(A201_03 == "Checked" ~ TRUE,
A201_03 == "Not checked" ~ FALSE,
A201_03 == NA ~ NA),
standardOtherWhich = as.factor(A201_03a),
likes = as.factor(as.character(A202)),
lived_in = as.factor(case_when(A203 == "I have not" ~ NA,
TRUE ~ as.character(A203))),
years_taught = as.numeric(str_extract(A204_01, "\\d+")),
native_lang = as.factor(case_when(A205 == "Other (please specify)" ~ as.character(A205_03),
TRUE ~ as.character(A205))),
age = as.numeric(str_extract(A206_01, "\\d+")),
.keep = "none")
summary(dg)
View(dg)
View(data_full)
# data in flat table format
d <- data_full %>% select(
participant,
starts_with("A10")) %>%
slice(-1) %>%
pivot_longer(
cols = -participant,
names_to = "item",
values_to = "rating"
) %>% separate(
item,
into = c("recording","characteristic"),
sep = "_"
) %>%
mutate(recording = as.factor(case_when(recording == "A101" ~ 1,
recording == "A102" ~ 2,
recording == "A103" ~ 3,
recording == "A104" ~ 4,
recording == "A105" ~ 5,
recording == "A106" ~ 6,
recording == "A107" ~ 7,
recording == "A108" ~ 8,
recording == "A109" ~ 9)),
characteristic = as.factor(case_when(
characteristic == "01" ~ "casual",
characteristic == "02" ~ "educated",
characteristic == "03" ~ "friendly",
characteristic == "04" ~ "good English",
characteristic == "05" ~ "normal",
characteristic == "06" ~ "polite")),
rating = as.numeric(case_when(
rating == "completely disagree" ~ 1,
rating == "partially disagree" ~ 2,
rating == "partially agree" ~ 3,
rating == "completely agree" ~ 4,
TRUE ~ NA)))
View(d)
# remove data from participants that did not complete the surevy
incomplete_ids <- d %>% group_by(participant) %>%
summarize(incomplete = any(is.na(rating)), .groups = "drop") %>%
filter(incomplete) %>% pull(participant)
d_clean <- d %>% filter(!participant %in% incomplete_ids)  %>% mutate(participant = fct_drop(participant)) %>% arrange(participant)
dg_clean <- dg %>% filter(!participant %in% incomplete_ids )%>% mutate(participant = fct_drop(participant)) %>% arrange(participant)
length(unique(d_clean$participant)) # 21 filled out the entire survey
levels(d_clean$participant) <- 1:length(unique(d_clean$participant))
levels(dg_clean$participant) <- 1:length(unique(d_clean$participant))
# replace participant by running number
length(unique(data_full$CASE)) # 81
# extract demographic data
dg <- data_full %>%
select(
participant,
starts_with("A20")
) %>%
slice(-1) %>%
mutate(participant = as.factor(participant),
standardAmE = case_when(A201_01 == "Checked" ~ TRUE,
A201_01 == "Not checked" ~ FALSE,
A201_01 == NA ~ NA),
standardBrE = case_when(A201_02 == "Checked" ~ TRUE,
A201_02 == "Not checked" ~ FALSE,
A201_02 == NA ~ NA),
standardOther = case_when(A201_03 == "Checked" ~ TRUE,
A201_03 == "Not checked" ~ FALSE,
A201_03 == NA ~ NA),
standardOtherWhich = as.factor(A201_03a),
likes = as.factor(as.character(A202)),
lived_in = as.factor(case_when(A203 == "I have not" ~ NA,
TRUE ~ as.character(A203))),
years_taught = as.numeric(str_extract(A204_01, "\\d+")),
native_lang = as.factor(case_when(A205 == "Other (please specify)" ~ as.character(A205_03),
TRUE ~ as.character(A205))),
age = as.numeric(str_extract(A206_01, "\\d+")),
.keep = "none")
# remove data from participants that did not complete the surevy
